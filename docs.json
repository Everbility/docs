{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Everbility Developer Docs",
  "colors": {
    "primary": "#5046E4",
    "light": "#806AE4",
    "dark": "#372FC2"
  },
  "favicon": "favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "developer-docs/index",
              "developer-docs/quickstart",
              "developer-docs/authentication",
              "developer-docs/scopes"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "developer-docs/uploads-and-transcription",
              "developer-docs/report-generation"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": {
          "source": "developer-docs/api/openapi.json",
          "directory": "developer-docs/api/reference"
        },
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "developer-docs/api/overview"
            ]
          },
          {
            "group": "Core endpoints",
            "pages": [
              "GET /v1/public/me",
              "GET /v1/public/clients/search",
              "GET /v1/public/clients/{client_id}/documents",
              "GET /v1/public/clients/{client_id}/documents/{document_id}"
            ]
          },
          {
            "group": "Templates",
            "pages": [
              "GET /v1/public/templates",
              "GET /v1/public/templates/{template_id}"
            ]
          },
          {
            "group": "Ingestion",
            "pages": [
              "POST /v1/public/clients/{client_id}/notes",
              "POST /v1/public/clients/{client_id}/notes/upload",
              "POST /v1/public/clients/{client_id}/transcriptions/upload-large",
              "GET /v1/public/jobs/{job_id}"
            ]
          },
          {
            "group": "Report generation",
            "pages": [
              "POST /v1/public/clients/{client_id}/reports/generate"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.everbility.com",
          "icon": "chart-line"
        },
        {
          "anchor": "Main site",
          "href": "https://www.everbility.com",
          "icon": "house"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Main site",
        "href": "https://www.everbility.com"
      },
      {
        "label": "Support",
        "href": "mailto:support@everbility.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Book demo",
      "href": "https://calendly.com/d/cp8d-fy7-mnp/everbility-demo"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
